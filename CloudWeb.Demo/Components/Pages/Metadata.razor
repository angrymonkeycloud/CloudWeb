@page "/metadata"
@inject CloudPage CloudPage

@code {
    protected override void OnInitialized()
    {
        CloudPage
            .SetTitle("Page Metadata")
            .SetDescription("Demonstrating per-page title, description, keywords, and favicon control using the CloudPage fluent API.")
            .SetKeywords("metadata, title, description, keywords, favicon, seo")
            .SetFavicon("/favicon.svg");
    }
}

<div class="page-header">
    <h1>Page Metadata</h1>
    <p class="lead">Control every <code>&lt;head&gt;</code> metadata tag per page through the <code>CloudPage</code> fluent API.</p>
</div>

<section class="section">
    <h2>Usage</h2>
    <p>Inject <code>CloudPage</code> into any Blazor component and call the fluent methods in <code>OnInitialized</code>.</p>
    <pre><code>@("@inject CloudPage CloudPage")

@("@code {")
    protected override void OnInitialized()
    {
        CloudPage
            .SetTitle("Page Metadata")
            .SetDescription("Per-page description, up to 160 characters.")
            .SetKeywords("blazor, seo, meta")
            .SetFavicon("/favicon.svg");
    }
}</code></pre>
</section>

<section class="section">
    <h2>Rendered Output for This Page</h2>
    <div class="result-grid">
        <div class="result-row">
            <span class="result-label">Title</span>
            <code>Page Metadata - CloudWeb Demo</code>
        </div>
        <div class="result-row">
            <span class="result-label">Description</span>
            <code>Demonstrating per-page title, description, keywords, and favicon control using the CloudPage fluent API.</code>
        </div>
        <div class="result-row">
            <span class="result-label">Keywords</span>
            <code>metadata, title, description, keywords, favicon, seo</code>
        </div>
        <div class="result-row">
            <span class="result-label">Favicon</span>
            <code>/favicon.svg</code>
        </div>
    </div>
</section>

<section class="section">
    <h2>API Reference</h2>
    <table class="api-table">
        <thead>
            <tr>
                <th>Method</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            <tr><td><code>SetTitle(string)</code></td><td>Sets the page title. The configured prefix and suffix are applied automatically.</td></tr>
            <tr><td><code>SetDescription(string)</code></td><td>Sets the meta description. Values over 160 characters are truncated with an ellipsis.</td></tr>
            <tr><td><code>SetKeywords(string)</code></td><td>Sets the meta keywords tag.</td></tr>
            <tr><td><code>SetFavicon(string)</code></td><td>Sets the favicon href. Overrides the global default when provided.</td></tr>
            <tr><td><code>SetTitleAddOns(IEnumerable&lt;string&gt;)</code></td><td>Appends additional tokens to the title, respecting the 64-character limit.</td></tr>
        </tbody>
    </table>
</section>

<section class="section">
    <h2>Global Defaults</h2>
    <p>Defaults are set in <code>AddCloudWeb</code>. Per-page values take precedence via null-coalescing.</p>
    <pre><code>builder.Services.AddCloudWeb(config =>
{
    config.TitlePrefix = "";
    config.TitleSuffix = " - My App";

    config.PageDefaults
        .SetFavicon("/favicon.svg")
        .SetDescription("Site-wide default description.")
        .SetKeywords("default, keywords");
});</code></pre>
</section>
